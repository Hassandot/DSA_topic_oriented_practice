def sumTheTree(node):
    if node is None:
        return 0
    leftSum=sumTheTree(node.left)
    rightSum=sumTheTree(node.right)
    return node.value + leftSum + rightSum

def countNode(node):
    if node is None:
        return 0
    leftSum=countNode(node.left)
    rightSum=countNode(node.right)
    return 1 + leftSum + rightSum
